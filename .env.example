# LLM provider: openrouter or groq
LLM_PROVIDER=openrouter

OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE
OPENROUTER_MODEL=deepseek/deepseek-chat-v3.1

GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
GROQ_MODEL=openai/gpt-oss-20b

# Qdrant: leave empty for embedded local storage at ./qdrant_data/
QDRANT_URL=

PORT=5050
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_N_HYBRID=20
TOP_K_RERANK=4
RRF_K=60
REWRITE_ENABLED=true
BGE_USE_FP16=1
INGEST_BATCH=32
